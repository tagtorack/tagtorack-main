# Environment variables for the contact form function (functions/api/contact.js).
#
# LOCAL DEV:  copy this file to ".dev.vars" and fill in real values.
#             .dev.vars is gitignored — never commit real values.
# PRODUCTION: set these in the Cloudflare dashboard at
#             Workers & Pages -> tagtorack-main -> Settings -> Variables and Secrets.

# REQUIRED — Resend API key (https://resend.com -> API Keys). Starts with "re_".
# Store as an ENCRYPTED secret in production.
RESEND_API_KEY=

# REQUIRED — where demo-request emails are delivered.
RECIPIENT_EMAIL=contact@tagtorack.com

# OPTIONAL — sender shown on the email. Must be on a Resend-verified domain.
# Defaults to "Tag to Rack <noreply@tagtorack.com>" if unset.
FROM_EMAIL=Tag to Rack <noreply@tagtorack.com>
