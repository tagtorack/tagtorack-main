# Environment variables for the contact form function (functions/api/contact.js).
#
# LOCAL DEV:  copy this file to ".dev.vars" and fill in real values.
#             .dev.vars is gitignored — never commit real values.
# PRODUCTION: set these in the Cloudflare dashboard at
#             Workers & Pages -> tagtorack -> Settings -> Variables and Secrets.

# REQUIRED — where contact / demo-request emails are delivered (via FormSubmit).
# Without this, the contact form returns a 500 "server_misconfigured" error.
RECIPIENT_EMAIL=contact@tagtorack.com

# OPTIONAL — phone number for SMS alerts (via TextBelt). Digits only or E.164.
RECIPIENT_PHONE=

# OPTIONAL — SMS-to-email gateway address; if set, it is CC'd on the email relay.
RECIPIENT_SMS_GATEWAY=
