# Normalize line endings: store text as LF in the repo and check out as LF.
# This prevents the whole-tree CRLF "everything modified" churn on Windows.
* text=auto eol=lf

# Explicit text types (kept LF)
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.jsonc text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.svg   text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets (never normalize)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.sqlite      binary
*.sqlite-shm  binary
*.sqlite-wal  binary
